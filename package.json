{
  "name": "shipyard",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "pnpm --filter @shipyard/server dev",
    "dev:web": "pnpm --filter @shipyard/web dev",
    "dev:worker": "pnpm --filter @shipyard/server worker",
    "build": "pnpm -r build",
    "lint": "eslint apps/web/src apps/server/src packages/shared/src --cache --max-warnings 0",
    "lint:recursive": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "typecheck:build": "tsc -b",
    "test": "pnpm --filter @shipyard/shared build && pnpm --filter @shipyard/shared test && pnpm --filter @shipyard/server test && pnpm --filter @shipyard/web test",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config e2e/playwright.config.ts",
    "db:migrate": "pnpm --filter @shipyard/server db:migrate",
    "db:migrate:deploy": "pnpm --filter @shipyard/server db:migrate:deploy",
    "db:generate": "pnpm --filter @shipyard/server db:generate",
    "db:studio": "pnpm --filter @shipyard/server db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "cpu-features",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "ssh2",
      "vue-demi",
      "vue-echarts"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.1",
    "vue-eslint-parser": "^10.4.0"
  }
}
