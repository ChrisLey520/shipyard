{
  "name": "shipyard",
  "private": true,
  "scripts": {
    "dev:server": "pnpm --filter @shipyard/server dev",
    "dev:web": "pnpm --filter @shipyard/web dev",
    "dev:worker": "pnpm --filter @shipyard/server worker",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @shipyard/server db:migrate",
    "db:studio": "pnpm --filter @shipyard/server db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "cpu-features",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "ssh2",
      "vue-demi",
      "vue-echarts"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
