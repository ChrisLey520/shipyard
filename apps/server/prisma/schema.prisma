generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── 用户与认证 ───────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String?
  avatarUrl    String?
  locale       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  oauthAccounts      UserOAuthAccount[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  orgMembers         OrgMember[]
  invitationsSent    OrgInvitation[]      @relation("InvitedBy")
  triggeredDeployments Deployment[]       @relation("TriggeredBy")
  approvalRequests   ApprovalRequest[]    @relation("RequestedBy")
  approvalReviews    ApprovalRequest[]    @relation("ReviewedBy")
  auditLogs          AuditLog[]
}

model UserOAuthAccount {
  id                String   @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── 组织与成员 ───────────────────────────────────────────────────────────────

model Organization {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  buildConcurrency   Int      @default(2)
  artifactRetention  Int      @default(10)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  members             OrgMember[]
  invitations         OrgInvitation[]
  gitAccounts         GitAccount[]
  projects            Project[]
  servers             Server[]
  auditLogs           AuditLog[]
  kubernetesClusters KubernetesCluster[]
  featureFlags        FeatureFlag[]
}

model OrgMember {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model OrgInvitation {
  id             String   @id @default(uuid())
  organizationId String
  email          String
  role           String
  token          String   @unique @default(uuid())
  status         String   @default("pending")
  expiresAt      DateTime
  invitedByUserId String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@index([organizationId])
  @@index([token])
}

// ─── 项目与配置 ───────────────────────────────────────────────────────────────

model Project {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  slug           String
  frameworkType  String
  repoFullName   String
  gitConnectionId String? @unique
  /// PR 预览：总开关
  previewEnabled    Boolean  @default(false)
  /// 预览部署目标 SSH 服务器（与 Environment.server 同源）
  previewServerId   String?
  /// 通配父域，例如 preview.example.com → FQDN 为 pr-{n}-{id8}.preview.example.com
  previewBaseDomain String?
  /// 可选：通知入队前消息模板；可用 {{message}} / {{body}} 嵌入系统默认文案，及其它既有占位符
  notificationMessageTemplate String? @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gitConnection  GitConnection?  @relation("ProjectGitConnection")
  previewServer  Server?         @relation("ProjectPreviewServer", fields: [previewServerId], references: [id], onDelete: SetNull)
  pipelineConfig PipelineConfig?
  buildEnvVars   ProjectBuildEnvVariable[]
  environments   Environment[]
  deployments    Deployment[]
  previews       Preview[]
  notifications  Notification[]
  featureFlags   FeatureFlag[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([previewServerId])
}

model PipelineConfig {
  id             String   @id @default(uuid())
  projectId      String   @unique
  installCommand String   @default("pnpm install")
  buildCommand   String   @default("pnpm build")
  lintCommand    String?
  testCommand    String?
  outputDir      String   @default("dist")
  nodeVersion    String   @default("20")
  cacheEnabled   Boolean  @default(true)
  timeoutSeconds Int      @default(900)
  ssrEntryPoint  String?
  /// PR 预览 SSR 蓝绿前远端 curl 使用的路径，如 /health；空则 /
  previewHealthCheckPath String?
  /// 启用后构建结束额外 docker build + push（Worker 须可用 Docker）
  containerImageEnabled Boolean @default(false)
  /// 镜像名不含 tag，如 registry.example.com/org/app
  containerImageName    String?
  /// 加密 JSON：{ "username"?: string, "password"?: string } 供 docker login
  containerRegistryAuthEncrypted String? @db.Text
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model GitConnection {
  id               String    @id @default(uuid())
  projectId        String    @unique
  gitProvider      String
  baseUrl          String?
  accessToken      String
  refreshToken     String?
  tokenExpiresAt   DateTime?
  gitUsername      String?
  webhookSecret    String
  remoteWebhookId  String?
  gitAccountId     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project    Project?    @relation("ProjectGitConnection", fields: [projectId], references: [id], onDelete: Cascade)
  gitAccount GitAccount? @relation(fields: [gitAccountId], references: [id], onDelete: SetNull)

  @@index([gitAccountId])
}

model GitAccount {
  id                  String    @id @default(uuid())
  organizationId    String
  name                String
  gitProvider         String
  baseUrl             String?
  accessToken         String
  gitUsername         String?
  authType            String    @default("pat")
  refreshToken        String?
  tokenExpiresAt      DateTime?
  providerAccountId   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gitConnections GitConnection[]

  @@index([organizationId])
  @@index([gitProvider])
  @@unique([organizationId, name])
}

model ProjectBuildEnvVariable {
  id        String   @id @default(uuid())
  projectId String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
}

// ─── 服务器与环境 ─────────────────────────────────────────────────────────────

model Server {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  host           String
  port           Int      @default(22)
  user           String
  privateKey     String
  os             String   @default("linux")
  /// PR 预览端口池下界（含）；为空时用应用内默认 40000
  previewPortMin Int?
  /// PR 预览端口池上界（含）；为空时用应用内默认 41000
  previewPortMax Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environments Environment[]
  environmentServers EnvironmentServer[]
  previewProjects Project[] @relation("ProjectPreviewServer")

  @@index([organizationId])
}

model Environment {
  id             String   @id @default(uuid())
  projectId      String
  name           String
  triggerBranch  String
  serverId       String
  deployPath     String
  domain         String?
  accessUrl      String?
  healthCheckUrl String?
  protected      Boolean  @default(false)
  /// 发布策略等（Zod 校验）；缺省等价于 ssh + direct
  releaseConfig       Json?
  /// SSH 静态/SSR 蓝绿：当前对外槽位 0 或 1；direct 策略可为 null
  blueGreenActiveSlot Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  server      Server       @relation(fields: [serverId], references: [id])
  environmentServers EnvironmentServer[]
  envVariables EnvVariable[]
  deployments  Deployment[]

  @@unique([projectId, name])
  @@index([projectId])
}

/// 环境多部署目标（rolling / 多机）；迁移时由 serverId 回填一条
model EnvironmentServer {
  id            String   @id @default(uuid())
  environmentId String
  serverId      String
  sortOrder     Int      @default(0)
  weight        Int      @default(100)

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  server      Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([environmentId, serverId])
  @@index([environmentId, sortOrder])
}

model EnvVariable {
  id            String   @id @default(uuid())
  environmentId String
  key           String
  value         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, key])
  @@index([environmentId])
}

// ─── 部署 ─────────────────────────────────────────────────────────────────────

model Deployment {
  id                String    @id @default(uuid())
  projectId         String
  environmentId     String?
  status            String    @default("queued")
  trigger           String    @default("manual")
  triggeredByUserId String?
  commitSha         String?
  branch            String?
  commitMessage     String?
  commitAuthor      String?
  configSnapshot    Json?
  artifactId        String?   @unique
  /// K8s 或容器部署记录的镜像 digest（可选）
  containerImageDigest String?
  containerImageRef    String?
  startedAt         DateTime?
  completedAt       DateTime?
  durationMs        Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment? @relation(fields: [environmentId], references: [id])
  triggeredBy User?        @relation("TriggeredBy", fields: [triggeredByUserId], references: [id])
  artifact    BuildArtifact? @relation("DeploymentArtifact")
  logs        DeploymentLog[]
  approvalRequest ApprovalRequest?
  preview     Preview?

  @@index([projectId])
  @@index([environmentId])
}

model DeploymentLog {
  id           String   @id @default(uuid())
  deploymentId String
  seq          Int
  content      String
  createdAt    DateTime @default(now())

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId, seq])
}

model BuildArtifact {
  id           String   @id @default(uuid())
  deploymentId String   @unique
  storagePath  String
  sizeBytes    BigInt   @default(0)
  imageDigest  String?
  imageRef     String?
  createdAt    DateTime @default(now())

  deployment Deployment @relation("DeploymentArtifact", fields: [deploymentId], references: [id], onDelete: Cascade)
}

/// 组织级或项目级特性开关（projectId 为空表示组织级；唯一性由应用层保证）
model FeatureFlag {
  id             String   @id @default(uuid())
  organizationId String
  projectId      String?
  key            String
  enabled        Boolean  @default(false)
  valueJson      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, projectId, key])
}

/// 加密存储 kubeconfig，仅 Deploy Worker 解密使用
model KubernetesCluster {
  id                   String   @id @default(uuid())
  organizationId       String
  name                 String
  kubeconfigEncrypted  String   @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ─── PR 预览 ──────────────────────────────────────────────────────────────────

model Preview {
  id           String    @id @default(uuid())
  projectId    String
  deploymentId String    @unique
  prNumber     Int
  prBranch     String
  url          String
  allocatedPort Int?
  /// SSR 预览蓝绿：最近一次成功部署后对外提供流量的槽位 0 或 1（对应 PM2 名 …-bg0 / …-bg1）
  ssrBgSlot    Int?
  gitProvider  String
  commentId    String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@unique([projectId, prNumber])
  @@index([projectId])
}

// ─── 审批 ─────────────────────────────────────────────────────────────────────

model ApprovalRequest {
  id                String    @id @default(uuid())
  deploymentId      String    @unique
  requestedByUserId String?
  reviewedByUserId  String?
  status            String    @default("pending")
  comment           String?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  deployment  Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  requestedBy User?      @relation("RequestedBy", fields: [requestedByUserId], references: [id])
  reviewedBy  User?      @relation("ReviewedBy", fields: [reviewedByUserId], references: [id])
}

// ─── 审计日志 ─────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  action         String
  resource       String
  resourceId     String?
  before         Json?
  after          Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
}

// ─── 通知配置 ─────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  projectId String
  channel   String
  config    Json
  events    String[]
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
