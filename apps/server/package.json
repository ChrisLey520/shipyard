{
  "name": "@shipyard/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "worker": "prisma generate && ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/worker.ts",
    "build": "prisma generate && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "start": "prisma generate && node dist/main.js",
    "start:worker": "prisma generate && node dist/worker.js",
    "db:migrate": "node scripts/run-prisma.cjs migrate dev",
    "db:migrate:deploy": "node scripts/run-prisma.cjs migrate deploy",
    "db:studio": "node scripts/run-prisma.cjs studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.2.0",
    "@nestjs/websockets": "^10.4.0",
    "@prisma/client": "^5.19.0",
    "@shipyard/shared": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/tar": "^7.0.87",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.14",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "ssh2": "^1.16.0",
    "tar": "^7.5.13",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.15",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/ssh2": "^1.15.1",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.19.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.0"
  }
}
