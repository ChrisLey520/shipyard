{
  "name": "@shipyard/monitoring-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "prisma generate && tsc",
    "start": "prisma generate && node dist/main.js",
    "start:e2e": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.2.0",
    "@prisma/client": "^5.19.0",
    "dotenv": "^17.4.1",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "source-map": "^0.7.6",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "prisma": "^5.19.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.17.0",
    "typescript": "^5.5.0",
    "@types/supertest": "^7.2.0",
    "vitest": "^2.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
