# 数据库
POSTGRES_USER=shipyard
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=shipyard
DATABASE_URL=postgresql://shipyard:change_me_in_production@localhost:5432/shipyard

# Redis
REDIS_URL=redis://localhost:6379

# JWT（至少 32 位随机字符串）
JWT_SECRET=change_me_at_least_32_chars_long_!!

# 加密主密钥（AES-256 用于加密 SSH 密钥、Git Token 等敏感数据）
ENCRYPTION_KEY=change_me_at_least_32_chars_long_!!

# 应用 URL
APP_URL=http://localhost:5173

# Web 本地开发代理（monorepo 根目录统一配置）
VITE_DEV_PROXY_TARGET=http://localhost:3000

# 邮件（可选，不填则不发送邮件）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourdomain.com

# PR Preview 域名（需配置 DNS 泛解析）
PREVIEW_DOMAIN=preview.yourdomain.com

# 构建产物存储路径
ARTIFACT_STORE_PATH=./artifacts
