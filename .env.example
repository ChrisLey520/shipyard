# 数据库
POSTGRES_USER=shipyard
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=shipyard
DATABASE_URL=postgresql://shipyard:change_me_in_production@localhost:5432/shipyard

# Redis
REDIS_URL=redis://localhost:6379

# JWT（至少 32 位随机字符串）
JWT_SECRET=change_me_at_least_32_chars_long_!!

# 加密主密钥（AES-256 用于加密 SSH 密钥、Git Token 等敏感数据）
ENCRYPTION_KEY=change_me_at_least_32_chars_long_!!

# 应用 URL
APP_URL=http://localhost:5173

# Server 对外访问地址（用于 Git 平台 Webhook 回调、OAuth redirect_uri）
# 例如： https://shipyard.yourdomain.com
SERVER_PUBLIC_URL=http://localhost:3000

# 可选：当 OAuth 回调域名与 SERVER_PUBLIC_URL 不同时配置（默认回退 SERVER_PUBLIC_URL）
# API_PUBLIC_URL=https://api.yourdomain.com

# Git OAuth（可选；不配则仅 PAT）。回调路径固定为：{SERVER_PUBLIC_URL}/api/git/oauth/{provider}/callback
GIT_OAUTH_GITHUB_CLIENT_ID=
GIT_OAUTH_GITHUB_CLIENT_SECRET=
GIT_OAUTH_GITLAB_CLIENT_ID=
GIT_OAUTH_GITLAB_CLIENT_SECRET=
# 自建 GitLab 时填写，例如 https://gitlab.example.com
GIT_OAUTH_GITLAB_HOST=https://gitlab.com
GIT_OAUTH_GITEE_CLIENT_ID=
GIT_OAUTH_GITEE_CLIENT_SECRET=
GIT_OAUTH_GITEA_HOST=
GIT_OAUTH_GITEA_CLIENT_ID=
GIT_OAUTH_GITEA_CLIENT_SECRET=

# Web 本地开发代理（monorepo 根目录统一配置）
VITE_DEV_PROXY_TARGET=http://localhost:3000

# 邮件（可选，不填则不发送邮件）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourdomain.com

# PR Preview 域名（需配置 DNS 泛解析）
PREVIEW_DOMAIN=preview.yourdomain.com

# 构建产物存储路径
ARTIFACT_STORE_PATH=./artifacts

# 可选：按组织 + lockfile 指纹复用 node_modules 的缓存根目录（默认系统临时目录下 shipyard-build-deps-cache）
# SHIPYARD_BUILD_DEPS_CACHE_PATH=/var/cache/shipyard-build-deps

# 依赖缓存总占用上限（超出后按指纹目录 mtime LRU 淘汰）。二选一；未设时默认约 5GiB
# SHIPYARD_BUILD_DEPS_CACHE_MAX_BYTES=5368709120
# SHIPYARD_BUILD_DEPS_CACHE_MAX_MB=5120

# Linux Worker：设为 true 时 install/lint/test/build 在 Docker 容器内执行（git clone 仍在宿主）；macOS/Windows 会记录告警并回退本机 child_process
# SHIPYARD_BUILD_USE_DOCKER=false
# 构建容器镜像（默认 node:20-bookworm，需含 bash 与常用包管理器）
# SHIPYARD_BUILD_DOCKER_IMAGE=node:20-bookworm
# Docker run 资源与安全（Linux + SHIPYARD_BUILD_USE_DOCKER=true 时生效）
# 默认 --network=bridge（勿用 none，否则无法拉包）；默认不 --privileged
# SHIPYARD_BUILD_DOCKER_NETWORK=bridge
# SHIPYARD_BUILD_DOCKER_CPUS=2
# SHIPYARD_BUILD_DOCKER_MEMORY=4g
# 高危，仅必要时 true
# SHIPYARD_BUILD_DOCKER_PRIVILEGED=false

# 依赖缓存：指纹目录超过若干天则先淘汰（再按组织配额、最后全局 LRU 字节上限）
# SHIPYARD_BUILD_DEPS_CACHE_MAX_AGE_DAYS=30
# 单组织缓存子树最大占用（二选一）
# SHIPYARD_BUILD_DEPS_CACHE_ORG_MAX_MB=1024
# SHIPYARD_BUILD_DEPS_CACHE_ORG_MAX_BYTES=

# CI 可选 Secret：GIT_SMOKE_BASE_URL（见 .github/workflows/ci.yml git-smoke job）
